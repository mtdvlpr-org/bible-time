{
  "name": "bible-time",
  "version": "1.1.0",
  "description": "An overview of Biblical people and events.",
  "homepage": "https://github.com/mtdvlpr-org/bible-time#readme",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mtdvlpr-org/bible-time.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:husky": "node .husky/install.mjs",
    "prepare:nuxt": "nuxt prepare",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "analyze": "nuxt analyze",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:types": "nuxt typecheck",
    "lint:commit": "commitlint -g config/commitlint.config.ts --edit",
    "test:unit": "vitest run --project browser --project server",
    "test:e2e": "vitest run --project e2e",
    "test:nuxt": "vitest run --project nuxt",
    "test": "vitest",
    "generate:pwa-assets": "pwa-assets-generator -c config/pwa-assets.config.ts & pwa-assets-generator -c config/maskable-assets.config.ts",
    "generate:supabase-types": "supabase gen types --lang=typescript --project-id pasnnzlggfefuzwhbakl > shared/database-generated.types.ts",
    "deploy": "pnpm generate:pwa-assets && pnpm build",
    "postinstall": "pnpm prepare:husky && pnpm prepare:nuxt"
  },
  "dependencies": {
    "@hcaptcha/vue3-hcaptcha": "^1.3.0",
